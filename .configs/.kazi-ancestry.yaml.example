# Copy to .configs/.kazi-ancestry.yaml and fill in. Secrets may also be passed
# via env (PGPASSWORD, GOOGLE_CLIENT_ID, GOOGLE_CLIENT_SECRET, SESSION_SECRET,
# ALLOWLIST, ADMIN_EMAILS), which override this file.

database:
  postgres:
    name: kazi
    host: localhost
    port: "5432"
    user: postgres
    password: postgres
    sslmode: disable

server:
  host: 0.0.0.0
  port: 5294
  webDir: web

auth:
  # Leave googleClientId/googleClientSecret empty for DEV MODE: /auth/login serves
  # a mock login form (pick admin or contributor). Fill them to enable Google OAuth.
  googleClientId: ""
  googleClientSecret: ""
  redirectUrl: http://localhost:5294/auth/callback
  sessionSecret: ""          # openssl rand -base64 32
  admins: []                 # emails that can edit + review
  allowlist: []              # emails that can suggest (others are read-only viewers)
  openSuggestions: true      # any logged-in user may suggest (not just allowlist)

privacy:
  guestNamesOnly: false      # true -> logged-out guests see only names (tree shape)

seedPath: web/family.local.json
