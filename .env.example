# Copy to .env and edit, then: docker compose up -d --build

# --- deploy ---
# Target architecture of the host where the image will run:
#   linux/amd64 (most cloud VMs) | linux/arm64 (ARM/Apple-silicon VM)
PLATFORM=linux/amd64
# Host port to publish (container listens on 5294).
HTTP_PORT=8080
ENV=production

# --- database (compose provisions Postgres with these) ---
PGDATABASE=kazi
PGUSER=kazi
PGPASSWORD=change-me

# --- auth (Google OAuth) ---
# Leave GOOGLE_CLIENT_ID/SECRET empty to run in OPEN DEV MODE (no login wall,
# every request is admin). Set them to enable the login wall.
# Create credentials at https://console.cloud.google.com/apis/credentials and
# add OAUTH_REDIRECT_URL as an authorized redirect URI.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
OAUTH_REDIRECT_URL=https://your.domain/auth/callback
# Long random string that signs session cookies (e.g. `openssl rand -base64 32`).
SESSION_SECRET=
# Comma-separated emails. Allowlist = contributors (may suggest edits);
# admins may edit directly and review the inbox. Empty allowlist admits any
# authenticated Google account as a contributor.
ALLOWLIST=
ADMIN_EMAILS=

# --- data ---
# Seed source on first boot (when the DB is empty). Defaults to the committed
# fictional sample. To load real data, mount web/family.local.json (see the
# commented volume in docker-compose.yml) and point this at it.
SEED_PATH=web/family.json
