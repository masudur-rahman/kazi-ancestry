# Copy to .env and edit, then: docker compose up -d --build

# Target architecture of where the image will RUN (the Debian VM):
#   linux/amd64  (most Debian VMs / cloud servers)
#   linux/arm64  (ARM VM, e.g. Ampere / Apple-silicon VM)
PLATFORM=linux/amd64

# Host port to publish (container always listens on 80)
HTTP_PORT=8080
